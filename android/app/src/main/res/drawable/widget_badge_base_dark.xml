<?xml version="1.0" encoding="utf-8"?>
<!-- widget_badge_base_light.xml과 같은 용도, 다크 모드용 — 밑그림 색만 다크
     배경(#1C1C1E, widget_bg 다크 값과 동일)으로 다름. 근무색을 덧입혔을 때
     "옅게 15%" 느낌이 라이트/다크 양쪽에서 자연스럽게 나오게 하려고 밑그림
     자체를 그 테마의 배경색에 맞춰둠(둘 다 흰 밑그림이면 다크 모드에서
     너무 밝게 뜸). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="#1C1C1E" />
    <corners android:radius="6dp" />
</shape>
